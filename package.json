{
  "name": "pkg-guard",
  "version": "0.2.0",
  "description": "Guard npm package manifests, entry points, and release workflows before publishing.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeremyaaron/pkg-guard.git"
  },
  "bugs": {
    "url": "https://github.com/jeremyaaron/pkg-guard/issues"
  },
  "homepage": "https://jeremyaaron.github.io/pkg-guard/",
  "type": "module",
  "bin": {
    "pkg-guard": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/mark-bin-executable.mjs",
    "verify:publish": "npm run lint && npm run typecheck && npm test && npm run build && node dist/cli/index.js check && npm pack --dry-run --ignore-scripts",
    "prepublishOnly": "npm run verify:publish",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "npm@10.8.2",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/semver": "^7.7.1",
    "@types/spdx-expression-parse": "^4.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "semver": "^7.8.4",
    "spdx-expression-parse": "^4.0.0",
    "yaml": "^2.9.0"
  }
}
